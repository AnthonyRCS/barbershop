NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barbershop
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/barbershop

# Staff JWT
JWT_SECRET=change_this_with_at_least_32_characters

# Platform (superadmin) JWT
PLATFORM_JWT_SECRET=change_this_platform_secret_min_32_chars

# Customer portal JWT (optional - required to enable /customer-portal endpoints)
# CUSTOMER_JWT_SECRET=change_this_customer_secret_min_32_chars

FRONTEND_URL=http://localhost:3000
# Optional: public app URL used for links in emails (password reset, customer verification)
# If omitted, backend uses the first FRONTEND_URL origin.
# FRONTEND_APP_URL=http://localhost:3000

# SMTP (optional - falls back to Ethereal test account in development)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=secret
# SMTP_FROM="Barbershop Pro" <noreply@barbershoppro.com>
